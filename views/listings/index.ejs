<% layout('layouts/boilerplate') %>

<body>
  <div class="container main-listings-container">

    <!-- Top Action Row (75% vs 25% Distribution) -->
    <div class="top-action-bar d-none d-md-flex">
      
      <!-- Left side (75%): Filters Bar Container + Next Arrow Button Controller -->
      <div class="filters-wrapper">
        <div id="filters">
          
          <a href="/listings?category=Trending" class="filter-link">
            <div class="filter <%= activeCategory === 'Trending' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-fire"></i><p>Trending</p>
            </div>
          </a>

          <a href="/listings?category=Rooms" class="filter-link">
            <div class="filter <%= activeCategory === 'Rooms' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-bed"></i><p>Rooms</p>
            </div>
          </a>

          <a href="/listings?category=Iconic cities" class="filter-link">
            <div class="filter <%= activeCategory === 'Iconic cities' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-mountain-city"></i><p>Iconic cities</p>
            </div>
          </a>

          <a href="/listings?category=Mountains" class="filter-link">
            <div class="filter <%= activeCategory === 'Mountains' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-mountain"></i><p>Mountains</p>
            </div>
          </a>

          <a href="/listings?category=Castles" class="filter-link">
            <div class="filter <%= activeCategory === 'Castles' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-fort-awesome"></i><p>Castles</p>
            </div>
          </a>

          <a href="/listings?category=Amazing pools" class="filter-link">
            <div class="filter <%= activeCategory === 'Amazing pools' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-person-swimming"></i><p>Amazing pools</p>
            </div>
          </a>

          <a href="/listings?category=Camping" class="filter-link">
            <div class="filter <%= activeCategory === 'Camping' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-campground"></i><p>Camping</p>
            </div>
          </a>

          <a href="/listings?category=Farms" class="filter-link">
            <div class="filter <%= activeCategory === 'Farms' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-cow"></i><p>Farms</p>
            </div>
          </a>

          <a href="/listings?category=Arctic" class="filter-link">
            <div class="filter <%= activeCategory === 'Arctic' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-snowflake"></i><p>Arctic</p>
            </div>
          </a>

          <a href="/listings?category=Beachfront" class="filter-link">
            <div class="filter <%= activeCategory === 'Beachfront' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-umbrella-beach"></i><p>Beachfront</p>
            </div>
          </a>

          <a href="/listings?category=Cabins" class="filter-link">
            <div class="filter <%= activeCategory === 'Cabins' ? 'active-filter' : '' %>">
              <i class="fa-solid fa-house-chimney-window"></i><p>Cabins</p>
            </div>
          </a>

        </div>
        
        <button class="scroll-next-btn" id="slide-right-btn" aria-label="Next categories">
          <i class="fa-solid fa-chevron-right"></i>
        </button>
      </div>

      <!-- Right side (25%): Fixed Proportional Static Switch Toggle Box -->
      <div class="tax-toggle-wrapper">
        <div class="tax-toggle shadow-sm">
          <div class="form-check form-switch form-check-reverse p-0 m-0 w-100 d-flex align-items-center justify-content-between">
            <label class="form-check-label text-dark" for="flexSwitchCheckDefault">Display total before taxes</label>
            <input class="form-check-input m-0" type="checkbox" role="switch" id="flexSwitchCheckDefault">
          </div>
        </div>
      </div>

    </div>

    <!-- Fallback filter row tracking exclusively on small devices -->
    <div class="d-flex d-md-none mb-2">
      <div id="filters" style="width: 100%;">
        <a href="/listings?category=Trending" class="filter-link"><div class="filter"><i class="fa-solid fa-fire"></i><p>Trending</p></div></a>
        <a href="/listings?category=Rooms" class="filter-link"><div class="filter"><i class="fa-solid fa-bed"></i><p>Rooms</p></div></a>
        <a href="/listings?category=Iconic cities" class="filter-link"><div class="filter"><i class="fa-solid fa-mountain-city"></i><p>Iconic</p></div></a>
        <a href="/listings?category=Castles" class="filter-link"><div class="filter"><i class="fa-solid fa-fort-awesome"></i><p>Castles</p></div></a>
      </div>
    </div>

    <!-- Listings Grid Cards Container Matrix -->
    <div class="row row-cols-1 row-cols-sm-1 row-cols-md-2 row-cols-lg-3 g-4 mt-0">
        
      <% if(data.length === 0) { %>
        <div class="col-12 text-center my-5">
          <i class="fa-regular fa-folder-open text-muted fs-1 mb-3"></i>
          <p class="text-muted">No listings found matching this criteria. Try exploring another filter!</p>
          <a href="/listings" class="btn btn-sm btn-outline-dark rounded-pill px-4">Clear Filters</a>
        </div>
      <% } else { %>
        <% for (let listing of data) { %>
          <div class="col">
            <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
              <div class="card h-100 listing-card border-0 shadow-sm">
                <!-- FIXED LINE HERE: Points to index [0] inside your array -->
                <img src="<%= listing.image && listing.image.length > 0 ? listing.image[0].url : '/images/placeholder.jpeg' %>" class="card-img-top listing-img" alt="listing image" style="height: 20rem; object-fit: cover; border-radius: 1rem;">
                <div class="card-img-overlay"></div>
                <div class="card-body px-1 py-3">
                  <b class="card-title bold text-dark d-block mb-1" style="font-size: 0.95rem;"><%= listing.title %></b> 
                  
                  <p class="card-text mb-1 text-muted" style="font-size: 0.85rem;">
                    Price: <span class="text-dark fw-bold">$<%= listing.price.toLocaleString("en-US") %></span> / night
                    <span class="tax-info ms-1 fw-semibold">&nbsp;+18% GST</span>
                  </p>
                  
                  <p class="card-text text-muted" style="font-size: 0.85rem;">Location: <%= listing.location %></p>
                </div>
              </div>
            </a>
          </div>
        <% } %>
      <% } %>
  
    </div>
  </div>

  <script>
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");
    taxSwitch.addEventListener("click", () => {
      let taxInfo = document.getElementsByClassName("tax-info");
      for (let info of taxInfo) {
        if (info.style.display !== "inline") {
          info.style.display = "inline";
        } else {
          info.style.display = "none";
        }
      }
    });

    const nextSliderBtn = document.getElementById("slide-right-btn");
    const filtersScrollContainer = document.getElementById("filters");

    nextSliderBtn.addEventListener("click", () => {
      const leapCalculationOffset = 260; 
      filtersScrollContainer.scrollBy({
        left: leapCalculationOffset,
        behavior: 'smooth'
      });
    });
  </script>
</body>
</html>