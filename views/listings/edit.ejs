<% layout('layouts/boilerplate') %>

<body>
    <br>
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h3 class="fw-bold mb-3">Edit Listing</h3>

            <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" novalidate
                class="needs-validation" enctype="multipart/form-data">
                
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="title">Listing Title</label>
                    <input type="text" placeholder="Add a catchy title" id="title" name="listing[title]"
                        value="<%= listing.title %>" class="form-control" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please provide a title for your listing.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold" for="description">Description</label>
                    <textarea placeholder="Description" id="description" name="listing[description]"
                        class="form-control" rows="4" required><%= listing.description %></textarea>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please provide a description for your listing.</div>
                </div>

                <!-- New Category Selection Dropdown Element -->
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="category">Category Type</label>
                    <select id="category" name="listing[category]" class="form-select py-2" required>
                        <option value="Trending" <%= listing.category === 'Trending' ? 'selected' : '' %>>Trending</option>
                        <option value="Rooms" <%= listing.category === 'Rooms' ? 'selected' : '' %>>Rooms</option>
                        <option value="Iconic cities" <%= listing.category === 'Iconic cities' ? 'selected' : '' %>>Iconic cities</option>
                        <option value="Mountains" <%= listing.category === 'Mountains' ? 'selected' : '' %>>Mountains</option>
                        <option value="Castles" <%= listing.category === 'Castles' ? 'selected' : '' %>>Castles</option>
                        <option value="Amazing pools" <%= listing.category === 'Amazing pools' ? 'selected' : '' %>>Amazing pools</option>
                        <option value="Camping" <%= listing.category === 'Camping' ? 'selected' : '' %>>Camping</option>
                        <option value="Farms" <%= listing.category === 'Farms' ? 'selected' : '' %>>Farms</option>
                        <option value="Arctic" <%= listing.category === 'Arctic' ? 'selected' : '' %>>Arctic</option>
                        <option value="Beachfront" <%= listing.category === 'Beachfront' ? 'selected' : '' %>>Beachfront</option>
                        <option value="Cabins" <%= listing.category === 'Cabins' ? 'selected' : '' %>>Cabins</option>
                    </select>
                    <div class="invalid-feedback">Please select a valid listing category.</div>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label class="form-label fw-semibold" for="price">Price</label>
                        <input placeholder="$1200" id="price" name="listing[price]" value="<%= listing.price %>"
                            class="form-control" required>
                        <div class="valid-feedback">Looks good!</div>
                        <div class="invalid-feedback">Please provide a price for your listing.</div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label class="form-label fw-semibold" for="location">Location</label>
                        <input type="text" placeholder="New York" id="location" name="listing[location]"
                            value="<%= listing.location %>" class="form-control" required>
                        <div class="valid-feedback">Looks good!</div>
                        <div class="invalid-feedback">Please provide a location for your listing.</div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold" for="country">Country</label>
                    <input type="text" placeholder="Country" id="country" name="listing[country]"
                        value="<%= listing.country %>" class="form-control" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please provide a country for your listing.</div>
                </div>
                
                <hr class="my-4 text-muted" />

                <!-- Multi-Image Thumbnail Previews Grid Section -->
                <div class="mb-4">
                    <label class="form-label fw-semibold d-block mb-2">Current Listing Gallery</label>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <% if(listing.image && listing.image.length > 0) { %>
                            <% listing.image.forEach(img => { %>
                                <img src="<%= img.url.replace('/upload', '/upload/w_250,h_150,c_fill') %>" 
                                     class="img-thumbnail shadow-sm" 
                                     alt="gallery item" 
                                     style="height: 6rem; width: 9rem; object-fit: cover; border-radius: 0.35rem;">
                            <% }) %>
                        <% } else { %>
                            <p class="text-muted small">No images currently uploaded.</p>
                        <% } %>
                    </div>
                    
                    <label class="form-label fw-semibold" for="image">Upload New Images (Optional)</label>
                    <!-- Enhanced multiple switch flag parameters -->
                    <input type="file" id="image" name="listing[image]" class="form-control py-2" multiple>
                    <div class="form-text text-muted" style="font-size: 0.72rem;">You can select up to 5 images at once to add to the existing gallery.</div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button class="btn btn-danger py-2 fw-bold shadow-sm" type="submit">Update Listing</button>
                </div>
            </form>
        </div>
    </div>
    <br><br>
</body>
</html>