<!-- Leaflet Map CSS CDN (Required to render map tiles correctly) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<% layout('layouts/boilerplate') %>

    <body>
        <div class="row mt-4">
            <div class="col-md-6 offset-md-3">
                <h3 class="fw-bold mb-3">
                    <%= data.title %>
                </h3>

                <div class="card listing-card shadow-sm h-100">
                    <img src="<%= data.image.url %>" class="card-img-top" alt="Listing Image"
                        style="height: 30rem; object-fit: cover;">

                    <div class="card-body px-0 py-3">
                       <p class="card-text text-muted mb-3">Owned by: <i><%= data.owner?.username || "anonymous" %></i></p>
                        
                        <p class="card-text text-muted mb-3">
                        <%= data.description %>
                        </p>

                        <p class="card-text mb-1">
                            <span class="fw-bold text-dark">Price:</span> $<%= data.price.toLocaleString("en-US") %>
                        </p>
                        <p class="card-text">
                            <span class="fw-bold text-dark">Location:</span>
                            <%= data.location %>, <%= data.country %>
                        </p>

                        <% if(currUser && currUser._id.equals(data.owner._id)) { %>
                        <div class="d-flex gap-3 mt-4">
                            <a href="/listings/<%= data._id %>/edit" class="btn btn-dark px-4 py-2 fw-semibold">Edit
                                Listing</a>

                            <form action="/listings/<%= data._id %>?_method=DELETE" method="POST" class="m-0">
                                <button type="submit" class="btn btn-danger px-4 py-2 fw-semibold">Delete
                                    Listing</button>
                            </form>
                        </div>
                        <% } %>

                        <hr />

                        <!-- Interactive Map Display Section -->
                        <div class="mb-4">
                            <h4 class="fw-bold mb-3">Where you'll be</h4>
                            <!-- We inject database variables into dataset-attributes for map.js to read safely -->
                            <div id="map" 
                                 style="height: 400px; width: 100%; border-radius: 12px; z-index: 1;" 
                                 class="shadow-sm border"
                                 data-coordinates="<%= JSON.stringify(data.geometry.coordinates) %>"
                                 data-title="<%= data.title %>"
                                 data-location="<%= data.location %>, <%= data.country %>">
                            </div>
                        </div>

                        <hr />

                        <div class="mb-5">
                            <% if(currUser) { %>
                            <h4 class="fw-bold mb-3">Leave a Review</h4>
                            <form action="/listings/<%= data._id %>/reviews" method="POST" novalidate
                                class="needs-validation">

                                <!-- Starability Rating Element Only -->
                                <div class="mb-3 mt-3">
                                    <label class="form-label">Rating</label>
                                    <fieldset class="starability-slot">
                                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                        
                                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                        <label for="first-rate1" title="Terrible">1 star</label>
                                        
                                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                        <label for="first-rate2" title="Not good">2 stars</label>
                                        
                                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                        <label for="first-rate3" title="Average">3 stars</label>
                                        
                                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                        <label for="first-rate4" title="Very good">4 stars</label>
                                        
                                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                        <label for="first-rate5" title="Amazing">5 stars</label>
                                    </fieldset>
                                </div>

                                <div class="mb-3 mt-3">
                                    <label for="comment" class="form-label">Comments</label>
                                    <textarea name="review[comment]" id="comment" cols="30" rows="5"
                                        class="form-control" placeholder="Write your experience here..."
                                        required></textarea>
                                    <div class="invalid-feedback">
                                        Please add some comment for the review.
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-outline-dark px-4 py-2 fw-semibold">Submit</button>
                            </form>

                            <hr />

                            <p><b>All Reviews</b></p>
                            <div class="row">
                                <% if (data.reviews.length===0) { %>
                                    <div class="col-12 mb-3">
                                        <p class="text-muted ms-1">No reviews yet.</p>
                                    </div>
                                    <% } else { %>
                                        <% for(let review of data.reviews) { %>
                                            <div class="card col-5 ms-3 mb-3 shadow-sm border-light">
                                                <div class="card-body">
                                                     <h5 class="card-title fw-semibold">@<%= review.author?.username || "anonymous" %></h5>
                                                    <p class="card-text mb-1">
                                                        <%= review.comment %>
                                                    </p>

                                                   <p class="starability-result" data-rating="<%= review.rating %>">
                                                        Rated: <%= review.rating %> stars
                                                    </p>
                                                    
                                                    <form
                                                        action="/listings/<%= data._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                        method="POST" class="mt-2 mb-1">
                                                        <button class="btn btn-sm btn-dark px-3 py-1">Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                            <% } %>
                                        <% } %>
                            </div>
                            <% } %>
                        </div>

                    </div>
                </div>

            </div>
        </div>

        <!-- Leaflet Map JS Engine -->
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
        
        <!-- Custom Client-Side Map Logic -->
        <script src="/js/map.js"></script>
    </body>

    </html>